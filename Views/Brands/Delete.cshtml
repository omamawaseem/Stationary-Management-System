@model Brand

@{
    ViewData["Title"] = "Delete Brand";
}

<partial name="_Notification" />

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0" style="max-width: 600px; width: 100%;">
        <div class="card-header bg-danger text-white py-3">
            <h2 class="h4 mb-0 text-center"><i class="bi bi-trash3-fill me-2"></i>Delete Brand</h2>
        </div>

        <div class="card-body p-4">
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                <div class="fw-bold">
                    Warning: This will permanently delete the brand and all associated categories and items! This action cannot be undone.
                </div>
            </div>

            <div class="border p-3 rounded mb-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Brand Name</dt>
                    <dd class="col-sm-8 fw-bold">
                        <i class="bi bi-building me-2"></i>@Model.BrandName
                    </dd>
                </dl>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="BrandID" />
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-danger btn-sm px-4">
                        <i class="bi bi-trash3-fill me-2"></i>Confirm Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>