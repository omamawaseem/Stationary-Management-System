@model WebApplication1.Models.Request

<div class="container mt-4 d-flex justify-content-center">
    <div class="card shadow-sm rounded-3" style="max-width: 500px; width: 100%;">
        <div class="card-header bg-light py-3 rounded-top-3">
            <div class="d-flex flex-column gap-2">
                <h4 class="mb-2 fw-bold fs-4 text-primary">Request Item</h4>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-box text-muted"></i>
                        <div>
                            <p class="mb-0 fw-medium">@Model.Item.ItemName</p>
                            <small class="text-muted">Item Name</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-tag text-muted"></i>
                        <div>
                            <p class="mb-0 fw-medium">@Model.Item.Category.Brand.BrandName</p>
                            <small class="text-muted">Brand</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-folder-open text-muted"></i>
                        <div>
                            <p class="mb-0 fw-medium">@Model.Item.Category.CategoryName</p>
                            <small class="text-muted">Category</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body p-3 p-lg-4">
            <form asp-action="CreateRequest" method="post">
                <input type="hidden" asp-for="ItemID" />

                <div class="mb-3">
                    <label asp-for="QuantityRequested" class="form-label fw-semibold">
                        Quantity Needed
                    </label>
                    <input asp-for="QuantityRequested"
                           class="form-control py-2"
                           placeholder="Enter quantity...">
                    <span asp-validation-for="QuantityRequested" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NeededDate" class="form-label fw-semibold">
                        Required By Date
                    </label>
                    <input asp-for="NeededDate" type="date"
                           class="form-control py-2">
                    <span asp-validation-for="NeededDate" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-gradient text-white btn-sm px-4 py-2">
                        <i class="fas fa-paper-plane me-2"></i>Submit
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .btn-gradient {
        background: linear-gradient(to right, #4f46e5, #6366f1);
        border: none;
        transition: all 0.2s ease;
        font-size: 0.9rem;
    }

        .btn-gradient:hover {
            background: linear-gradient(to right, #6366f1, #4f46e5);
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(79, 70, 229, 0.2);
        }

    .form-control {
        font-size: 0.9rem;
        border: 1px solid #dee2e6;
    }

    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
    }

    .fa-box, .fa-tag, .fa-folder-open {
        width: 20px;
        text-align: center;
    }

    .text-muted {
        color: #6c757d !important;
    }
</style>