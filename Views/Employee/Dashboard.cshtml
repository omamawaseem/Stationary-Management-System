@model IEnumerable<WebApplication1.Models.Request>
<partial name="_Notification" />
@{
    ViewData["Title"] = "Employee Dashboard";
    var employees = ViewBag.Employees as List<WebApplication1.Models.Employee>;
    
}

<!-- Bootstrap CSS -->


<div class="container-fluid px-4">
    <!-- Header Section -->
    <!-- Header Section -->
    <header class="d-flex justify-content-between align-items-center py-3 mb-3 border-bottom bg-secondary text-white px-3 rounded">
        <h1 class="h5 mb-0"><i class="bi bi-speedometer2 me-2"></i>Employee Dashboard</h1>
        <p class="mb-0">Welcome Back, <span class="fw-bold">@ViewData["Name"]</span></p>
    </header>

    <!-- Main Content -->
    <div class="card border-0 shadow-lg">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>Your Requests</h5>
                <a asp-action="Browse" class="btn btn-light btn-sm">
                    <i class="bi bi-plus-circle me-2"></i>New Request
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class ="ps-2">Request ID</th>
                            <th class="ps-4">Item</th>
                            <th>Quantity</th>
                            <th>Date Needed</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td class ="ps-2">@request.RequestID</td>
                                <td class="ps-4 fw-medium">@request.Item.ItemName</td>
                                <td>@request.QuantityRequested</td>
                                <td>@request.NeededDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @{
                                        var statusClass = request.Status switch
                                        {
                                            "Pending" => "warning",
                                            "Approved" => "success",
                                            "Rejected" => "danger",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@statusClass rounded-pill">@request.Status</span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (request.Status == "Pending")
                                    {
                                        <a asp-action="CancelRequest" asp-route-id="@request.RequestID"
                                           class="btn btn-outline-warning btn-sm me-2">
                                            <i class="bi bi-x-circle"></i> Cancel
                                        </a>
                                    }
                                    else
                                    {
                                        <form asp-action="DeleteRequest" asp-route-id="@request.RequestID" method="post">
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-dark fs-1"></i>
                    <p class="text-muted mt-3">No requests found. Create your first request!</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Bootstrap JS and dependencies -->


@section Scripts {
    <!-- Toastr notifications -->
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (ViewBag.Notifications != null)
    {
        <script type="text/javascript">
            $(document).ready(function () {
            @foreach (var notification in ViewBag.Notifications)
            {
                @:toastr.success('@Html.Raw(notification.Message)');
            }
                                    });
        </script>
    }

    <!-- Prevent back navigation script -->
    <script>
        history.replaceState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
    </script>
}