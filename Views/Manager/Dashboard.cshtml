@model IEnumerable<WebApplication1.Models.Request>
<partial name="_Notification" />
@{
    ViewData["Title"] = "Manager Dashboard";
    var brands = ViewBag.Brands as List<WebApplication1.Models.Brand>;
    var categories = ViewBag.Categories as List<WebApplication1.Models.Category>;
    var items = ViewBag.Items as List<WebApplication1.Models.Item>;
    var employees = ViewBag.Employees as List<WebApplication1.Models.Employee>;

}



<div class="container-fluid px-4 py-4">
    <!-- Header Section -->
    <header class="d-flex justify-content-between align-items-center py-2 mb-3 border-bottom bg-success text-white px-3 rounded">
        <h1 class="h5 mb-0"><i class="bi bi-person-circle me-2"></i>Manager Dashboard</h1>
        <p class="mb-0">Welcome Back, <span class="fw-bold">@ViewData["Name"]</span></p>
    </header>

    <!-- Pending Requests Card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-primary text-white py-2">
            <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Pending Requests</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="p>Request ID</th>
                            <th>Employee</th>
                            <th>Item</th>
                            <th>Quantity</th>
                            <th>Date Needed</th>
                            <th class="pe-4 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in Model)
                        {
                            var employee = employees.FirstOrDefault(e => e.EmployeeNumber == req.EmployeeNumber);
                            <tr>
                                <td class="ps-4 fw-medium">#@req.RequestID</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-person-circle me-2 text-muted"></i>
                                        <span>@employee?.Name</span>
                                    </div>
                                </td>
                                <td>@req.Item?.ItemName</td>
                                <td>
                                    <span class="badge bg-primary rounded-pill">
                                        @req.QuantityRequested
                                    </span>
                                </td>
                                <td>@req.NeededDate.ToString("MMM dd, yyyy")</td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-action="ApproveRequest" asp-route-id="@req.RequestID"
                                           class="btn btn-sm btn-success">
                                            <i class="bi bi-check-circle me-2"></i>Approve
                                        </a>
                                        <a asp-action="RejectRequest" asp-route-id="@req.RequestID"
                                           class="btn btn-sm btn-danger">
                                            <i class="bi bi-x-circle me-2"></i>Reject
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted fs-1"></i>
                    <p class="text-dark mt-3">No pending requests found</p>
                </div>
            }
        </div>
    </div>

    <!-- Management Tools Card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-secondary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-tags me-2"></i>Brands</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Brand ID</th>
                            <th>Name</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var brand in brands)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@brand.BrandID</td>
                                <td>@brand.BrandName</td>
                                <td class="action-buttons">
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="Brands" asp-action="Edit" asp-route-id="@brand.BrandID">Edit</a>
                                    <a class="btn btn-sm btn-outline-danger" asp-controller="Brands" asp-action="Delete" asp-route-id="@brand.BrandID">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Categories Table -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-info text-white py-3">
            <h5 class="mb-0"><i class="bi bi-list-task me-2"></i>Categories</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Category ID</th>
                            <th>Name</th>
                            <th>Brand</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in categories)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@category.CategoryID</td>
                                <td>@category.CategoryName</td>
                                <td>@category.Brand?.BrandName</td>
                                <td class="action-buttons">
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="Categories" asp-action="Edit" asp-route-id="@category.CategoryID">Edit</a>
                                    <a class="btn btn-sm btn-outline-danger" asp-controller="Categories" asp-action="Delete" asp-route-id="@category.CategoryID">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Items Table -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-success text-white py-3">
            <h5 class="mb-0"><i class="bi bi-box-seam me-2"></i>Items</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Item ID</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Brand</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@item.ItemID</td>
                                <td>@item.ItemName</td>
                                <td>@item.Category?.CategoryName</td>
                                <td>@item.Brand?.BrandName</td>
                                <td class="action-buttons">
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="Items" asp-action="Edit" asp-route-id="@item.ItemID">Edit</a>
                                    <a class="btn btn-sm btn-outline-danger" asp-controller="Items" asp-action="Delete" asp-route-id="@item.ItemID">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        history.replaceState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
    </script>
}