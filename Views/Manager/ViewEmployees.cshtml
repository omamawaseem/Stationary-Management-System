@model IEnumerable<WebApplication1.Models.Employee>
<partial name="_Notification" />
@{
    ViewData["Title"] = "View Employees";
}

<div class="container mt-4">
    <!-- Success/Error Messages -->


    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Delete Employee</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this employee? This action cannot be undone.</p>
                    <form id="deleteForm" asp-action="DeleteEmployee" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="employeeId" />
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="deleteForm" class="btn btn-danger">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Employee Table -->
    <div class="card shadow">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Employee Number</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var employee in Model)
                            {
                                <tr>
                                    <td>@employee.EmployeeNumber</td>
                                    <td>@employee.Name</td>
                                    <td>@employee.Email</td>
                                    <td>
                                        <span class="badge bg-primary">@employee.Role</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-danger btn-sm delete-btn" 
                                                data-id="@employee.EmployeeNumber"
                                                data-name="@employee.Name"
                                                data-bs-toggle="modal" 
                                                data-bs-target="#deleteModal">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    No employees found. Start by adding new employees using the "Add Employee" button.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const deleteButtons = document.querySelectorAll('.delete-btn');
            const deleteForm = document.getElementById('deleteForm');
            const employeeIdInput = document.getElementById('employeeId');
            const modalBody = document.querySelector('#deleteModal .modal-body p');

            deleteButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const employeeId = this.dataset.id;
                    const employeeName = this.dataset.name;
                    employeeIdInput.value = employeeId;
                    modalBody.textContent = `Are you sure you want to delete ${employeeName} (ID: ${employeeId})? This action cannot be undone.`;
                });
            });

            deleteForm.addEventListener('submit', function() {
                // Add loading state if needed
                document.querySelector('#deleteModal .btn-danger').disabled = true;
            });
        });
    </script>
}