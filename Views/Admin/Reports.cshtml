@model IEnumerable<WebApplication1.Models.ReportViewModel>

@{
    ViewData["Title"] = "Stationery Usage Report";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="display-8 fw-bold text-primary">📊 Stationery Usage Report</h4>
    </div>

    <div class="card border-0 shadow-lg">
        <div class="card-header bg-primary bg-gradient py-3">
            <h4 class="mb-0 text-white"><i class="fas fa-check-circle me-2"></i>Approved Requests Summary</h4>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Item Name</th>
                            <th>Brand</th>
                            <th>Category</th>
                            <th>Employee</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end pe-4">Total Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-square bg-light-primary text-primary rounded-circle me-2">
                                            <i class="fas fa-cube"></i>
                                        </div>
                                        @item.ItemName
                                    </div>
                                </td>
                                <td>@item.BrandName</td>
                                <td><span class="badge bg-info">@item.CategoryName</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-user-circle me-2 text-secondary"></i>
                                        @item.EmployeeName
                                    </div>
                                </td>
                                <td class="text-end">@item.QuantityRequested</td>
                                <td class="text-end fw-bold pe-4">@item.TotalCost.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="4" class="text-end fw-bold ps-4">Grand Total:</td>
                            <td class="text-end fw-bold text-primary">@Model.Sum(i => i.QuantityRequested)</td>
                            <td class="text-end fw-bold text-primary pe-4">@Model.Sum(i => i.TotalCost).ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-4 text-muted text-center">
        <small>Report generated on @DateTime.Now.ToString("MMMM dd, yyyy h:mm tt")</small>
    </div>
</div>
