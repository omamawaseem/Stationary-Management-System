
<partial name="_Notification" />
@{
    ViewData["Title"] = "Admin Dashboard";
   
    var brands = ViewBag.Brands as List<WebApplication1.Models.Brand>;
    var categories = ViewBag.Categories as List<WebApplication1.Models.Category>;
    var items = ViewBag.Items as List<WebApplication1.Models.Item>;
  
 
}


<!-- Bootstrap CSS -->
<link href="cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.css" />

<!-- Header Section -->
<header class="d-flex justify-content-between align-items-center py-3 mb-3 border-bottom bg-primary text-white px-3 rounded">
    <h1 class="h5 mb-0"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h1>
    <p class="mb-0">Welcome Back, <span class="fw-bold">@ViewData["Name"]</span></p>
</header>


<!-- Brands Table -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-secondary text-white py-3">
        <h5 class="mb-0"><i class="bi bi-tags me-2"></i>Brands</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Brand ID</th>
                        <th>Name</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var brand in brands)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@brand.BrandID</td>
                            <td>@brand.BrandName</td>
                            <td class="action-buttons">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Brands" asp-action="Edit" asp-route-id="@brand.BrandID">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="Brands" asp-action="Delete" asp-route-id="@brand.BrandID">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Categories Table -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-info text-white py-3">
        <h5 class="mb-0"><i class="bi bi-list-task me-2"></i>Categories</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Category ID</th>
                        <th>Name</th>
                        <th>Brand</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in categories)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@category.CategoryID</td>
                            <td>@category.CategoryName</td>
                            <td>@category.Brand?.BrandName</td>
                            <td class="action-buttons">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Categories" asp-action="Edit" asp-route-id="@category.CategoryID">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="Categories" asp-action="Delete" asp-route-id="@category.CategoryID">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Items Table -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white py-3">
        <h5 class="mb-0"><i class="bi bi-box-seam me-2"></i>Items</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Item ID</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@item.ItemID</td>
                            <td>@item.ItemName</td>
                            <td>@item.Category?.CategoryName</td>
                            <td>@item.Brand?.BrandName</td>
                            <td class="action-buttons">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Items" asp-action="Edit" asp-route-id="@item.ItemID">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="Items" asp-action="Delete" asp-route-id="@item.ItemID">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Managers Table -->

@section Scripts {
    <script>
        history.replaceState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
    </script>
}
