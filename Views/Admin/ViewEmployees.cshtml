@model List<WebApplication1.Models.Employee>
<partial name="_Notification" />
@{
    ViewData["Title"] = "Manage Employees";
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-warning text-dark py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-people me-2"></i>Employees</h5>
        <a class="btn btn-light btn-sm" asp-action="AddEmployee">
            <i class="bi bi-person-plus me-2"></i>Add Employee
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Employee #</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Superior</th>
                        <th>Superior Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@e.EmployeeNumber</td>
                            <td>@e.Name</td>
                            <td>@e.Email</td>
                            <td>@(e.Superior?.Name ?? "N/A")</td>
                            <td>
                                <span class="badge bg-success role-badge">@(e.Superior?.Role ?? "N/A")</span>
                            </td>
                            <td>
                                <form asp-action="DeleteEmployee" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@e.EmployeeNumber" />
                                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                </form>
                                <a asp-action="EditEmployee" asp-route-id="@e.EmployeeNumber" class="btn btn-primary btn-sm">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>