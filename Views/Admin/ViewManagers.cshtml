@model List<WebApplication1.Models.Employee>
<partial name="_Notification" />
@{
    ViewData["Title"] = "Manage Managers";
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-info text-dark py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Managers</h5>
        <a class="btn btn-light btn-sm" asp-action="AddManager">
            <i class="bi bi-person-plus me-2"></i>Add Manager
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Employee #</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Acions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@m.EmployeeNumber</td>
                            <td>@m.Name</td>
                            <td>@m.Email</td>
                            <td>
                                <span class="badge bg-info role-badge">@m.Role</span>
                            </td>
                            <td>
                                <form asp-action="DeleteManager" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@m.EmployeeNumber" />
                                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                </form>
                                <a asp-action="EditManager" asp-route-id="@m.EmployeeNumber" class="btn btn-primary btn-sm">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>