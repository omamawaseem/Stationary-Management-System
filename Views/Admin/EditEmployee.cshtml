@model WebApplication1.Models.Employee
@{
    ViewData["Title"] = "Edit Employee";
    var managers = ViewBag.Managers as List<WebApplication1.Models.Employee>;
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded">
            <div class="card-header bg-primary text-white text-center">
                <h3 class="mb-0"><i class="bi bi-pencil-fill"></i> Edit Employee</h3>
            </div>
            <div class="card-body">
                <form method="post" class="needs-validation" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                    <input type="hidden" asp-for="EmployeeNumber" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Full Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-bold">Role</label>
                        <input asp-for="Role" class="form-control" />
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SuperiorEmployeeNumber" class="form-label fw-bold">Superior</label>
                        <select asp-for="SuperiorEmployeeNumber" class="form-control">
                            <option value="">-- Select Manager --</option>
                            @foreach (var manager in managers)
                            {
                                <option value="@manager.EmployeeNumber">@manager.Name</option>
                            }
                        </select>
                        <span asp-validation-for="SuperiorEmployeeNumber" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="ViewEmployees" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save-fill"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}